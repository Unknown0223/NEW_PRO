# ESKI usul — endi .env.local / .env.production ishlating.
# Lokal:  copy .env.local  yoki  ..\scripts\env\switch-local.ps1
# Server: copy .env.production  yoki  ..\scripts\env\switch-production-mobile.ps1
#
# Debug avtomatik .env.local, release APK avtomatik .env.production yuklaydi.
API_BASE_URL=http://127.0.0.1:18080
# Lokal login (faqat .env.local da):
DEFAULT_TENANT_SLUG=test1
DEFAULT_LOGIN=agent

# Yandex Maps **JavaScript API** kaliti (Static API emas!)
# Marshrut chiziqlari yo'l bo'yicha: kalit tavsiya etiladi.
# YANDEX_MAPS_API_KEY=your_js_api_key_here
# Kalitsiz xarita + OSRM zaxira marshrut (internet kerak):
YANDEX_MAPS_NO_API_KEY=1
