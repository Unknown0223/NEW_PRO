# SALEC Frontend — muhit o'zgaruvchilari (namuna)

# Virtual Pivot Engine — default yoqilgan (/reports/builder → pivot).
# Rollback uchun WebDataRocks: /reports/builder/wdr
# To'liq o'chirish: NEXT_PUBLIC_PIVOT_ENGINE=false
NEXT_PUBLIC_PIVOT_ENGINE=true

# Standalone pivot demo URL (ixtiyoriy)
# NEXT_PUBLIC_PIVOT_DEMO_URL=http://127.0.0.1:5174

# Soft-void arxiv/restore UI — default yoqilgan. O‘chirish: NEXT_PUBLIC_SOFT_VOID_V1=0
# (Backend soft-void qoladi; hard delete qayta yoqilmaydi.)
# NEXT_PUBLIC_SOFT_VOID_V1=1
