{
  "name": "savdo-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "postinstall": "prisma generate",
    "dev:prep": "node scripts/wait-for-postgres.cjs && prisma migrate deploy && node scripts/prisma-generate-if-needed.cjs",
    "predev": "node scripts/wait-for-postgres.cjs && prisma migrate deploy && node scripts/prisma-generate-if-needed.cjs",
    "dev": "tsx watch src/index.ts",
    "dev:server": "tsx watch src/index.ts",
    "worker:dev": "tsx watch src/worker/index.ts",
    "worker:start": "node dist/src/worker/index.js",
    "build": "tsc -p tsconfig.json",
    "openapi:generate": "tsx scripts/openapi/generate-schemas.ts",
    "openapi:lint": "npx --yes @apidevtools/swagger-cli@4.0.4 validate openapi/openapi.bundle.yaml",
    "openapi:lint:skeleton": "npx --yes @apidevtools/swagger-cli@4.0.4 validate openapi/skeleton.yaml",
    "audit:route-tenant": "node scripts/audit-route-tenant-context.mjs",
    "audit:max-loc": "node scripts/audit-max-file-lines.mjs",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "start": "node dist/src/index.js",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:contracts": "vitest run tests/contracts-schemas.unit.test.ts tests/report-builder-schemas.unit.test.ts tests/mobile-schemas.unit.test.ts",
    "test:coverage:orders": "vitest run tests/order-bonus-apply.pure.test.ts tests/bonus-and-discount.pure.test.ts tests/orders-domain-coverage.smoke.test.ts --coverage",
    "perf:explain": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/perf/run-all-explain.ps1",
    "perf:p95": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/perf/summarize-p95-from-log.ps1",
    "perf:sample-p95": "tsx scripts/perf/sample-foundation-p95.ts",
    "perf:sample-p95:quick": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:P95_PROFILE='quick'; $env:FOUNDATION_P95_QUIET='1'; npx tsx scripts/perf/sample-foundation-p95.ts\"",
    "perf:bench-order-debts": "tsx scripts/perf/bench-order-debts-once.ts",
    "foundation:ops": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/perf/run-foundation-ops.ps1",
    "foundation:verify": "npm run foundation:verify:fast && npm run build",
    "foundation:perf:gate": "npm run perf:sample-p95:quick && npm run perf:bench-order-debts",
    "foundation:verify:fast": "npm run test:contracts && npm run audit:route-tenant && npm run audit:max-loc && npm run openapi:generate && npm run openapi:lint && node scripts/perf/validate-grafana-dashboard.mjs",
    "test:supervisor-dashboard": "vitest run tests/dashboard-supervisor.integration.test.ts",
    "test:client-qr": "vitest run tests/client-qr.integration.test.ts",
    "test:work-slots": "vitest run tests/work-slots.pure.test.ts tests/work-slots.integration.test.ts",
    "test:report-builder": "vitest run tests/report-builder-validate.test.ts tests/report-builder.integration.test.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "seed:polki-return-scenarios": "tsx scripts/seed-polki-return-scenarios-once.ts",
    "seed:return-filter-test": "tsx scripts/seed-return-filter-test-once.ts",
    "db:seed": "prisma db seed",
    "backfill:work-slots": "tsx scripts/backfill-work-slots.ts",
    "db:zero-reset": "tsx scripts/db-zero-reset.ts",
    "db:wipe:all-once": "node scripts/db-wipe-all-once.cjs",
    "import:bundle": "tsx scripts/load-import-bundle.ts",
    "import:active-agents-xlsx": "tsx scripts/import-active-agents-xlsx.ts",
    "import:supervisors-xlsx": "tsx scripts/import-supervisors-xlsx.ts",
    "import:expeditors-xlsx": "tsx scripts/import-expeditors-xlsx.ts",
    "import:staff:triple": "tsx scripts/import-staff-triple-xlsx.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "audit:retention": "tsx scripts/audit-retention.ts",
    "audit:territory-codes": "tsx scripts/audit-territory-codes.ts",
    "import:refs": "tsx scripts/import-reference-bundle.ts",
    "import:staff-csv": "tsx scripts/import-staff-from-csv.ts",
    "ensure:demo-logins": "tsx scripts/ensure-demo-staff-login.ts",
    "provision:admin": "tsx scripts/provision-tenant-admin.ts",
    "import:once": "tsx scripts/import-once.ts",
    "sync:staff-xlsx": "node scripts/sync-staff-xlsx-from-downloads.cjs",
    "analyze:staff-xlsx": "tsx scripts/analyze-user-staff-xlsx.ts",
    "validate:staff-xlsx": "tsx scripts/analyze-user-staff-xlsx.ts",
    "import:cities-xlsx": "tsx scripts/import-cities-xlsx.ts",
    "import:territory-excel": "tsx scripts/import-territory-excel.ts",
    "import:excel-bundle": "tsx scripts/import-excel-bundle.ts",
    "import:tenant-data": "npm run import:once && npm run import:excel-bundle",
    "territory:sync-codes": "tsx scripts/sync-territory-codes.ts",
    "seed:agent-gps-once": "tsx scripts/seed-agent-gps-pings-once.ts",
    "reset:clients-once": "tsx scripts/reset-clients-once.ts",
    "seed:orders-full-test-once": "tsx scripts/seed-orders-full-test-once.ts",
    "seed:supervisor-dashboard-full-once": "tsx scripts/seed-supervisor-dashboard-full-once.ts",
    "rbac:backfill": "tsx scripts/backfill-access-rbac.ts",
    "access:parse-legacy-permissions": "node scripts/parse-legacy-permissions.mjs",
    "access:seed-legacy-permissions": "tsx scripts/seed-legacy-permissions.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.73.4",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.10.1",
    "jszip": "^3.10.1",
    "pdfkit": "^0.18.0",
    "pino-pretty": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.1",
    "@types/pdfkit": "^0.17.5",
    "@types/readable-stream": "^4.0.23",
    "@vitest/coverage-v8": "^2.1.9",
    "prisma": "^6.0.0",
    "supertest": "^7.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "yaml": "^2.9.0",
    "zod-to-json-schema": "^3.25.2"
  }
}
