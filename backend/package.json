{
  "name": "savdo-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "prepare": "node scripts/install-husky.cjs",
    "postinstall": "prisma generate",
    "dev:prep": "node scripts/wait-for-postgres.cjs && prisma migrate deploy && node scripts/prisma-generate-if-needed.cjs",
    "predev": "node scripts/wait-for-postgres.cjs && prisma migrate deploy && node scripts/prisma-generate-if-needed.cjs",
    "dev": "tsx watch src/index.ts",
    "dev:server": "tsx watch src/index.ts",
    "worker:dev": "tsx watch src/worker/index.ts",
    "worker:start": "node dist/src/worker/index.js",
    "build": "tsc -p tsconfig.json",
    "openapi:generate": "tsx scripts/openapi/generate-schemas.ts",
    "openapi:lint": "npx --yes @apidevtools/swagger-cli@4.0.4 validate openapi/openapi.bundle.yaml",
    "openapi:lint:skeleton": "npx --yes @apidevtools/swagger-cli@4.0.4 validate openapi/skeleton.yaml",
    "audit:route-tenant": "node scripts/audit-route-tenant-context.mjs",
    "audit:max-loc": "node scripts/audit-max-file-lines.mjs",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "start": "node dist/src/index.js",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:contracts": "vitest run tests/contracts-schemas.unit.test.ts tests/report-builder-schemas.unit.test.ts tests/mobile-schemas.unit.test.ts",
    "test:coverage:orders": "vitest run tests/order-bonus-apply.pure.test.ts tests/bonus-and-discount.pure.test.ts tests/order-bonus-match-scope.pure.test.ts tests/order-status.test.ts tests/permission-crud-model.pure.test.ts tests/mobile-bonus-preview-filter.unit.test.ts tests/coverage-gate.pure.test.ts --coverage",
    "perf:explain": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/perf/run-all-explain.ps1",
    "perf:p95": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/perf/summarize-p95-from-log.ps1",
    "perf:sample-p95": "tsx scripts/perf/sample-foundation-p95.ts",
    "perf:sample-p95:quick": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:P95_PROFILE='quick'; $env:FOUNDATION_P95_QUIET='1'; npx tsx scripts/perf/sample-foundation-p95.ts\"",
    "perf:bench-order-debts": "tsx scripts/perf/bench-order-debts-once.ts",
    "foundation:ops": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/perf/run-foundation-ops.ps1",
    "foundation:verify": "npm run foundation:verify:fast && npm run build",
    "foundation:perf:gate": "npm run perf:sample-p95:quick && npm run perf:bench-order-debts",
    "foundation:verify:fast": "npm run test:contracts && npm run audit:route-tenant && npm run audit:max-loc && npm run openapi:generate && npm run openapi:lint && node scripts/perf/validate-grafana-dashboard.mjs",
    "test:supervisor-dashboard": "vitest run tests/dashboard-supervisor.integration.test.ts",
    "test:client-qr": "vitest run tests/client-qr.integration.test.ts",
    "test:work-slots": "vitest run tests/work-slots.pure.test.ts tests/work-slots.codes.pure.test.ts tests/work-slots.integration.test.ts",
    "work-slots:verify": "vitest run tests/work-slots.pure.test.ts tests/work-slots.codes.pure.test.ts tests/work-slots.integration.test.ts",
    "smoke:order-automation": "tsx scripts/smoke-order-automation.ts",
    "test:order-automation": "vitest run tests/order-automation.engine.test.ts tests/order-automation.integration.test.ts",
    "test:report-builder": "vitest run tests/report-builder-validate.test.ts tests/report-builder.integration.test.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "seed:polki-return-scenarios": "tsx scripts/seed-polki-return-scenarios-once.ts",
    "seed:return-filter-test": "tsx scripts/seed-return-filter-test-once.ts",
    "db:seed": "prisma db seed && npm run rbac:migrate-crud",
    "mobile:perms": "tsx scripts/ensure-mobile-role-permissions.ts",
    "rbac:ensure": "tsx scripts/ensure-rbac-tenant.ts",
    "rbac:migrate-crud": "tsx scripts/migrate-permissions-to-crud.ts test1",
    "rbac:migrate-legacy": "tsx scripts/migrate-legacy-permissions.ts test1",
    "dostup:verify": "npm run rbac:migrate-crud && vitest run tests/route-permission-guard.pure.test.ts tests/route-permission-coverage.pure.test.ts tests/rbac.permissions.pure.test.ts tests/access-api.integration.test.ts tests/rbac-enforcement.integration.test.ts tests/contract-smoke.integration.rbac.test.ts",
    "polki:verify": "vitest run tests/returns-bonus-reverse.preview.test.ts tests/returns-bonus-reverse.peresort.test.ts tests/returns-enhanced.bonus-debt.test.ts tests/client-balance-ledger.bonus-debt.test.ts tests/period-return-route.schema.test.ts",
    "refaktoring:verify": "npm run audit:max-loc && npm run test:contracts && vitest run tests/refaktoring-barrels.pure.test.ts tests/orders-domain-coverage.smoke.test.ts tests/order-bonus-apply.pure.test.ts tests/bonus-and-discount.pure.test.ts tests/orders.integration.create.test.ts tests/orders.integration.patch.test.ts tests/orders.integration.rules.test.ts tests/orders.integration.rbac.test.ts",
    "bitta-ilova:verify": "vitest run tests/mobile-schemas.unit.test.ts tests/mobile-expeditor-schemas.unit.test.ts tests/app-release.unit.test.ts tests/agent-mobile-config.test.ts tests/agent-mobile-config.sync-policy.unit.test.ts tests/agent-mobile-config.client-mobile.unit.test.ts tests/mobile-sync-agent-scope.test.ts tests/mobile-expeditor.service.unit.test.ts tests/mobile-expeditor-peresort.test.ts tests/mobile-bonus-preview.integration.test.ts tests/mobile-order-policy.pure.test.ts tests/client-photo-reports-scope.pure.test.ts",
    "plans:verify": "vitest run tests/plans-schemas.pure.test.ts tests/plans-approvers.integration.test.ts tests/order-approval.pure.test.ts",
    "prod:ops-check": "tsx scripts/prod-ops-check.ts",
    "prod:verify": "npm run prod:ops-check && vitest run tests/prod-deploy.pure.test.ts && npm run foundation:verify:fast && npm run dostup:verify && npm run polki:verify && npm run work-slots:verify && npm run refaktoring:verify && npm run bitta-ilova:verify && npm run plans:verify",
    "agents:config": "tsx scripts/ensure-agent-standard-config.ts",
    "agents:enable-create": "tsx scripts/enable-agent-client-create-once.ts",
    "backfill:work-slots": "tsx scripts/backfill-work-slots.ts",
    "db:zero-reset": "tsx scripts/db-zero-reset.ts",
    "db:wipe:all-once": "node scripts/db-wipe-all-once.cjs",
    "import:bundle": "tsx scripts/load-import-bundle.ts",
    "import:active-agents-xlsx": "tsx scripts/import-active-agents-xlsx.ts",
    "import:supervisors-xlsx": "tsx scripts/import-supervisors-xlsx.ts",
    "import:expeditors-xlsx": "tsx scripts/import-expeditors-xlsx.ts",
    "import:staff:triple": "tsx scripts/import-staff-triple-xlsx.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "audit:retention": "tsx scripts/audit-retention.ts",
    "audit:territory-codes": "tsx scripts/audit-territory-codes.ts",
    "import:refs": "tsx scripts/import-reference-bundle.ts",
    "import:staff-csv": "tsx scripts/import-staff-from-csv.ts",
    "ensure:demo-logins": "tsx scripts/ensure-demo-staff-login.ts",
    "provision:admin": "tsx scripts/provision-tenant-admin.ts",
    "railway:prod-init": "tsx scripts/railway-prod-init.ts",
    "import:once": "tsx scripts/import-once.ts",
    "sync:staff-xlsx": "node scripts/sync-staff-xlsx-from-downloads.cjs",
    "analyze:staff-xlsx": "tsx scripts/analyze-user-staff-xlsx.ts",
    "validate:staff-xlsx": "tsx scripts/analyze-user-staff-xlsx.ts",
    "import:cities-xlsx": "tsx scripts/import-cities-xlsx.ts",
    "import:gorod-xlsx": "tsx scripts/import-gorod-xlsx.ts",
    "import:territory-excel": "tsx scripts/import-territory-excel.ts",
    "import:excel-bundle": "tsx scripts/import-excel-bundle.ts",
    "import:tenant-data": "npm run import:once && npm run import:excel-bundle",
    "backfill:client-codes": "tsx scripts/backfill-client-codes-xlsx.ts",
    "territory:sync-codes": "tsx scripts/sync-territory-codes.ts",
    "seed:agent-gps-once": "tsx scripts/seed-agent-gps-pings-once.ts",
    "seed:agent-route-map-once": "tsx scripts/seed-agent-route-map-once.ts",
    "reset:clients-once": "tsx scripts/reset-clients-once.ts",
    "seed:orders-full-test-once": "tsx scripts/seed-orders-full-test-once.ts",
    "seed:supervisor-dashboard-full-once": "tsx scripts/seed-supervisor-dashboard-full-once.ts",
    "seed:komanda-test-five": "tsx scripts/seed-komanda-test-five.ts",
    "rbac:backfill": "tsx scripts/backfill-access-rbac.ts",
    "access:parse-legacy-permissions": "node scripts/parse-legacy-permissions.mjs",
    "access:seed-legacy-permissions": "tsx scripts/seed-legacy-permissions.ts",
    "backup:pre-release": "bash scripts/backup/pg-backup.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/client": "^6.0.0",
    "@sentry/node": "^8.55.2",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.73.4",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.10.1",
    "jszip": "^3.10.1",
    "opossum": "^10.0.0",
    "pdfkit": "^0.18.0",
    "pino-pretty": "^13.0.0",
    "polygon-clipping": "^0.15.7",
    "prom-client": "^15.1.3",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.1",
    "@types/opossum": "^8.1.9",
    "@types/pdfkit": "^0.17.5",
    "@types/readable-stream": "^4.0.23",
    "@vitest/coverage-v8": "^2.1.9",
    "husky": "^9.1.7",
    "prisma": "^6.0.0",
    "supertest": "^7.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "yaml": "^2.9.0",
    "zod-to-json-schema": "^3.25.2"
  }
}
