# SALEC backend — namuna (nusxa: cp .env.example .env)
# Maxfiy qiymatlarni repoga commit qilmang.
# To'liq jadval: docs/PRODUCTION_DEPLOY_CHECKLIST.md

# --- Asosiy ---
NODE_ENV=development
PORT=18080

# --- Database (REQUIRED prod) ---
# Lokal Docker: infrastructure/docker-compose, host port 15432
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:15432/savdo_db

# --- Redis (REQUIRED prod) ---
REDIS_URL=redis://127.0.0.1:16479
# REDIS_SENTINEL_HOSTS=sentinel1:26379,sentinel2:26379
# REDIS_SENTINEL_MASTER_NAME=mymaster

# --- JWT (REQUIRED prod, ≥32 belgi) ---
# Generatsiya: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# --- CORS (REQUIRED prod) ---
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- RBAC (REQUIRED prod = 1) ---
# RBAC_ENFORCE_PERMISSIONS=0

# --- Health / metrics (RECOMMENDED prod) ---
# INTERNAL_HEALTH_TOKEN=change-me-min-16-chars

# --- Multipart limitlari (OPTIONAL) ---
# MULTIPART_MAX_FILE_BYTES=33554432
# MULTIPART_EXCEL_MAX_BYTES=26214400
# MULTIPART_APK_MAX_BYTES=125829120

# --- Rate limit (OPTIONAL) ---
# AUTH_LOGIN_RATE_MAX=30
# AUTH_LOGIN_RATE_WINDOW_MS=900000
# WRITE_API_RATE_MAX=120
# WRITE_API_RATE_WINDOW_MS=60000

# --- Monitoring (OPTIONAL) ---
# SENTRY_DSN=https://xxx@o000.ingest.sentry.io/000
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_SERVICE_NAME=salec-backend
# LOG_SAMPLE_RATE=1.0

# --- Object storage R2/S3 (OPTIONAL — yoqilmasa lokal disk) ---
# STORAGE_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# STORAGE_BUCKET=salec-uploads
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_PUBLIC_BASE_URL=https://cdn.example.com

# --- Push (OPTIONAL) ---
# FCM_SERVER_KEY=

# --- Activity tracking (OPTIONAL) ---
# ACTIVITY_TRACKING_ENABLED=1
# ACTIVITY_RETENTION_DAYS=90
# ERROR_EVENT_RETENTION_DAYS=90
# AUDIT_RETENTION_DAYS=730
# PHOTO_CONTENT_RETENTION_DAYS=60
# Tenant override (JSON): settings.audit_retention_days

# Soft-void v1: default 1. Backend always soft-voids (flag does NOT re-enable hard delete).
# Set 0 to signal UI to hide archive/restore (pair with NEXT_PUBLIC_SOFT_VOID_V1=0).
# SOFT_VOID_V1=1

# --- Dashboard perf (OPTIONAL) ---
# DASHBOARD_PERF_LOG=0
# DASHBOARD_SNAPSHOT_CACHE_TTL_SECONDS=60
# DASHBOARD_CACHE_WARMING=0

# --- Order create tuning (OPTIONAL) ---
# ORDER_CREATE_PRODUCT_CHUNK=750
# ORDER_CREATE_PRODUCT_CHUNK_PARALLEL=4
# LINKAGE_AGENT_SOLD_PRODUCT_IDS_LIMIT=8000

# --- Dev / debug (OPTIONAL) ---
# PRISMA_QUERY_LOG=1
# PRISMA_SLOW_QUERY_MS=100
