# SALEC backend — namuna (nusxa: cp .env.example .env)
# Maxfiy qiymatlarni repoga commit qilmang.

NODE_ENV=development
PORT=18080

# PostgreSQL (lokal Docker: infrastructure/docker-compose)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/savdo_db

# Redis (dashboard kesh, navbat, order SSE)
REDIS_URL=redis://localhost:6379

# JWT — har biri kamida 32 belgi (generatsiya: openssl rand -hex 32)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Productionda majburiy: vergul bilan ajratilgan origin lar
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# Ixtiyoriy
# DASHBOARD_PERF_LOG=1
# DASHBOARD_SNAPSHOT_CACHE_TTL_SECONDS=90
# PRISMA_QUERY_LOG=1
# PRISMA_SLOW_QUERY_MS=100
