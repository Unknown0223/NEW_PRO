model WorkSlot {
  id                 Int                     @id @default(autoincrement())
  tenant_id          Int
  slot_code          String                  @db.VarChar(32)
  label              String?                 @db.VarChar(128)
  branch_code        String?                 @db.VarChar(120)
  direction_id       Int?
  slot_type          String                  @default("agent") @db.VarChar(32)
  is_active          Boolean                 @default(true)
  sort_order         Int                     @default(0)
  /// Joy konfiguratsiyasi (P0): manba — slot; faol userga mirror.
  territory          String?
  warehouse_id       Int?
  return_warehouse_id Int?
  cash_desk_id       Int?
  price_type         String?
  price_types        Json                    @default("[]")
  entitlements       Json                    @default("{}")
  consignment        Boolean                 @default(false)
  consignment_limit_amount Decimal?          @db.Decimal(15, 2)
  consignment_ignore_previous_months_debt Boolean @default(false)
  consignment_close_day    Int               @default(25)
  consignment_close_hour   Int               @default(0)
  consignment_close_minute Int               @default(0)
  supervisor_user_id Int?
  warehouse_staff_entitlements Json          @default("{}")
  expeditor_assignment_rules   Json          @default("{}")
  created_at         DateTime                @default(now())
  updated_at         DateTime                @updatedAt
  deleted_at         DateTime?
  deleted_by_user_id Int?
  tenant             Tenant                  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  direction          TradeDirection?         @relation(fields: [direction_id], references: [id], onDelete: SetNull)
  deleted_by         User?                   @relation("WorkSlotVoidedBy", fields: [deleted_by_user_id], references: [id], onDelete: SetNull)
  warehouse          Warehouse?              @relation("WorkSlotWarehouse", fields: [warehouse_id], references: [id], onDelete: SetNull)
  return_warehouse   Warehouse?              @relation("WorkSlotReturnWarehouse", fields: [return_warehouse_id], references: [id], onDelete: SetNull)
  cash_desk          CashDesk?               @relation("WorkSlotCashDesk", fields: [cash_desk_id], references: [id], onDelete: SetNull)
  supervisor         User?                   @relation("WorkSlotSupervisor", fields: [supervisor_user_id], references: [id], onDelete: SetNull)
  user_links         SlotUserLink[]
  audit_entries      SlotAuditEntry[]
  client_assignments ClientAgentAssignment[]

  @@unique([tenant_id, slot_code])
  @@index([tenant_id, branch_code])
  @@index([tenant_id, slot_type, is_active])
  @@index([tenant_id, deleted_at])
  @@index([warehouse_id])
  @@index([cash_desk_id])
  @@map("work_slots")
}

/// Hozirgi yoki tarixiy xodim ↔ ishchi o‘rni.

model SlotUserLink {
  id         Int       @id @default(autoincrement())
  tenant_id  Int
  slot_id    Int
  user_id    Int
  started_at DateTime  @default(now())
  ended_at   DateTime?
  ended_by   Int?
  note       String?
  created_at DateTime  @default(now())
  slot       WorkSlot  @relation(fields: [slot_id], references: [id], onDelete: Cascade)
  user       User      @relation("SlotUserLinks", fields: [user_id], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, slot_id, ended_at])
  @@index([tenant_id, user_id, ended_at])
  @@map("slot_user_links")
}

/// Ishchi o‘rnida xodim almashinuvi tarixi.

model SlotAuditEntry {
  id           Int      @id @default(autoincrement())
  tenant_id    Int
  slot_id      Int
  prev_user_id Int?
  next_user_id Int?
  action       String   @db.VarChar(32)
  actor_id     Int?
  note         String?
  created_at   DateTime @default(now())
  slot         WorkSlot @relation(fields: [slot_id], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  actor        User?    @relation("SlotAuditActor", fields: [actor_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, slot_id, created_at(sort: Desc)])
  @@map("slot_audit_entries")
}

/// Mijoz hisob saldosi (yozuvlar yig‘indisi bilan sinxron).

model ClientBalance {
  id         Int                     @id @default(autoincrement())
  tenant_id  Int
  client_id  Int
  balance    Decimal                 @default(0) @db.Decimal(15, 2)
  updated_at DateTime                @updatedAt
  movements  ClientBalanceMovement[]
  client     Client                  @relation(fields: [client_id], references: [id])
  tenant     Tenant                  @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, client_id])
  @@index([tenant_id])
  @@index([tenant_id, balance])
  @@map("client_balances")
}


model ClientBalanceMovement {
  id                Int           @id @default(autoincrement())
  client_balance_id Int
  delta             Decimal       @db.Decimal(15, 2)
  note              String?
  user_id           Int?
  created_at        DateTime      @default(now())
  client_balance    ClientBalance @relation(fields: [client_balance_id], references: [id], onDelete: Cascade)
  user              User?         @relation(fields: [user_id], references: [id])

  @@index([client_balance_id])
  @@index([client_balance_id, created_at(sort: Desc)])
  @@map("client_balance_movements")
}

/// Boshlang‘ich qoldiq (Lalaku: «Начальные балансы клиентов») — yozuv + balansga bir martalik delta.

model ClientOpeningBalanceEntry {
  id                 Int       @id @default(autoincrement())
  tenant_id          Int
  client_id          Int
  /// debt = долг (balansdan ayirish); surplus = излишек (balansga qo‘shish)
  balance_type       String    @db.VarChar(24)
  amount             Decimal   @db.Decimal(15, 2)
  payment_type       String    @db.VarChar(64)
  cash_desk_id       Int?
  trade_direction    String?   @db.VarChar(128)
  note               String?
  paid_at            DateTime?
  created_at         DateTime  @default(now())
  created_by_user_id Int?
  deleted_at         DateTime?
  deleted_by_user_id Int?
  delete_reason_ref  String?   @db.VarChar(128)
  client             Client    @relation(fields: [client_id], references: [id], onDelete: Cascade)
  tenant             Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  cash_desk          CashDesk? @relation(fields: [cash_desk_id], references: [id], onDelete: SetNull)
  created_by         User?     @relation("OpeningBalanceCreator", fields: [created_by_user_id], references: [id])
  deleted_by         User?     @relation("OpeningBalanceVoidedBy", fields: [deleted_by_user_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, created_at(sort: Desc)])
  @@index([tenant_id, client_id])
  @@index([tenant_id, deleted_at])
  @@map("client_opening_balance_entries")
}

/// Mijoz bo‘yicha admin/operator harakatlari (PATCH, balans, birlashtirish).

model ClientAuditLog {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  client_id  Int
  user_id    Int?
  action     String
  detail     Json     @default("{}")
  created_at DateTime @default(now())
  client     Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [user_id], references: [id])

  @@index([tenant_id, client_id])
  @@index([tenant_id, client_id, action])
  @@map("client_audit_logs")
}

/// Yagona audit jurnal — barcha muhim entitylar (staff, product, warehouse, …).

model TenantAuditEvent {
  id            Int      @id @default(autoincrement())
  tenant_id     Int
  actor_user_id Int?
  entity_type   String   @db.VarChar(64)
  entity_id     String   @db.VarChar(64)
  action        String   @db.VarChar(128)
  payload       Json     @default("{}")
  created_at    DateTime @default(now())
  actor         User?    @relation("TenantAuditEventActor", fields: [actor_user_id], references: [id])
  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, created_at(sort: Desc)])
  @@index([tenant_id, entity_type, entity_id])
  @@map("tenant_audit_events")
}

/// Foydalanuvchi xatti-harakatlari: sahifa ko'rish, navigatsiya, qancha vaqt
/// turgani va "tahrir/yaratish formasini ochdi lekin saqlamadi" kabi niyatlar.
/// Mutatsiyalardan (TenantAuditEvent) alohida — hajmi katta, retention bilan.

model UserActivityEvent {
  id            Int      @id @default(autoincrement())
  tenant_id     Int
  actor_user_id Int?
  /// page_view | navigation | view_intent | form_open | form_abandon
  event_type    String   @db.VarChar(32)
  module        String   @db.VarChar(64)
  section       String?  @db.VarChar(64)
  entity_type   String?  @db.VarChar(64)
  entity_id     String?  @db.VarChar(64)
  route         String?  @db.VarChar(255)
  label         String?  @db.VarChar(255)
  duration_ms   Int?
  meta          Json     @default("{}")
  created_at    DateTime @default(now())
  actor         User?    @relation("UserActivityEventActor", fields: [actor_user_id], references: [id])
  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, created_at(sort: Desc)])
  @@index([tenant_id, actor_user_id, created_at(sort: Desc)])
  @@index([tenant_id, module, section])
  @@index([tenant_id, entity_type, entity_id])
  @@map("user_activity_events")
}

/// Diagnostika: faqat xatoliklar (mobil client + backend API).
/// Muvaffaqiyatli so‘rovlar yozilmaydi. Retention: ERROR_EVENT_RETENTION_DAYS (default 90).

model ErrorEvent {
  id           Int       @id @default(autoincrement())
  tenant_id    Int
  user_id      Int?
  /// mobile | backend
  source       String    @db.VarChar(16)
  /// error | fatal
  severity     String    @db.VarChar(16) @default("error")
  occurred_at  DateTime  @default(now())
  created_at   DateTime  @default(now())
  request_id   String?   @db.VarChar(64)
  http_status  Int?
  error_code   String?   @db.VarChar(128)
  message      String    @db.VarChar(500)
  path         String?   @db.VarChar(255)
  method       String?   @db.VarChar(16)
  /// android | ios | server
  platform     String    @db.VarChar(16)
  apk_version  String?   @db.VarChar(64)
  device_name  String?   @db.VarChar(128)
  device_id    String?   @db.VarChar(128)
  /// sync | orders | visits | auth | other
  module       String?   @db.VarChar(64)
  payload      Json      @default("{}")
  user         User?     @relation("ErrorEventUser", fields: [user_id], references: [id], onDelete: SetNull)
  tenant       Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, occurred_at(sort: Desc)])
  @@index([tenant_id, user_id, occurred_at(sort: Desc)])
  @@index([tenant_id, request_id])
  @@index([tenant_id, source, occurred_at(sort: Desc)])
  @@map("error_events")
}


model Warehouse {
  id             Int                 @id @default(autoincrement())
  tenant_id      Int
  name           String
  type           String?
  address        String?
  created_at     DateTime            @default(now())
  updated_at     DateTime            @updatedAt
  code           String?             @db.VarChar(40)
  /// To‘lov usuli (ixtiyoriy matn)
  payment_method String?             @db.VarChar(200)
  /// Van-selling ombor
  van_selling    Boolean             @default(false)
  is_active      Boolean             @default(true)
  /// Остатки: sales = склад реализации, return = возврат, reserve = резерв
  stock_purpose  String              @default("sales") @db.VarChar(16)
  goods_receipts GoodsReceipt[]
  orders         Order[]
  sales_returns  SalesReturn[]
  stock          Stock[]
  stock_takes    StockTake[]
  warehouse_corrections WarehouseCorrection[]
  users_return   User[]              @relation("UserReturnWarehouse")
  users_default  User[]              @relation("UserWarehouse")
  work_slots     WorkSlot[]          @relation("WorkSlotWarehouse")
  work_slots_return WorkSlot[]       @relation("WorkSlotReturnWarehouse")
  links          WarehouseUserLink[]
  blocks         WarehouseBlock[]
  tenant         Tenant              @relation(fields: [tenant_id], references: [id])
  clients        Client[]            @relation("ClientWarehouse")

  @@index([tenant_id])
  @@map("warehouses")
}

/// Ombor ichidagi fizik zona / blok (shelf zone, cold storage, …)

model WarehouseBlock {
  id                         Int       @id @default(autoincrement())
  tenant_id                  Int
  warehouse_id               Int
  name                       String    @db.VarChar(300)
  code                       String?   @db.VarChar(20)
  sort_order                 Int       @default(0)
  is_active                  Boolean   @default(true)
  comment                    String?   @db.VarChar(2000)
  /// «Blokda tovar yo‘qligi» tasdiqlangan vaqt (operatsion)
  empty_stock_confirmed_at   DateTime?
  /// Shu blokdagi yig‘ishni bajaradigan gruzchik (`User.role = gruzchik`)
  gruzchik_user_id           Int?
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt
  warehouse                  Warehouse @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)
  tenant                     Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  gruzchik_user              User?     @relation("WarehouseBlockGruzchik", fields: [gruzchik_user_id], references: [id], onDelete: SetNull)
  expeditors                 WarehouseBlockExpeditor[]
  orders                     Order[]

  @@index([tenant_id, warehouse_id])
  @@index([tenant_id, is_active])
  @@index([gruzchik_user_id])
  @@map("warehouse_blocks")
}


model WarehouseBlockExpeditor {
  block_id Int
  user_id  Int
  block    WarehouseBlock @relation(fields: [block_id], references: [id], onDelete: Cascade)
  user     User           @relation("WarehouseBlockExpeditorUser", fields: [user_id], references: [id], onDelete: Cascade)

  @@id([block_id, user_id])
  @@index([user_id])
  @@map("warehouse_block_expeditors")
}

/// Omborga biriktirilgan foydalanuvchi (bir foydalanuvchi bir omborda bitta link_role)

model WarehouseUserLink {
  id           Int       @id @default(autoincrement())
  warehouse_id Int
  user_id      Int
  /// agent | cashier | manager | operator | supervisor | expeditor (kassa bilan mos)
  link_role    String    @db.VarChar(32)
  created_at   DateTime  @default(now())
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  warehouse    Warehouse @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)

  @@unique([warehouse_id, user_id])
  @@index([warehouse_id, link_role])
  @@index([user_id])
  @@map("warehouse_user_links")
}


model Stock {
  id           Int       @id @default(autoincrement())
  tenant_id    Int
  warehouse_id Int
  product_id   Int
  qty          Decimal   @default(0) @db.Decimal(15, 3)
  reserved_qty Decimal   @default(0) @db.Decimal(15, 3)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  product      Product   @relation(fields: [product_id], references: [id])
  tenant       Tenant    @relation(fields: [tenant_id], references: [id])
  warehouse    Warehouse @relation(fields: [warehouse_id], references: [id])

  @@unique([tenant_id, warehouse_id, product_id])
  @@index([tenant_id])
  @@map("stock")
}

/// Ombor korrektirovkasi / inventarizatsiya hujjati (jurnal qatori + pozitsiyalar).

model WarehouseCorrection {
  id                 Int       @id @default(autoincrement())
  tenant_id          Int
  warehouse_id       Int
  created_by_user_id Int?
  /// correction — delta kiritish; inventory_count — haqiqiy qoldiqdan hisoblangan delta
  kind               String    @db.VarChar(32)
  price_type         String?   @db.VarChar(128)
  occurred_at        DateTime  @default(now())
  comment            String?   @db.VarChar(2000)
  total_qty_delta    Decimal   @db.Decimal(15, 3)
  total_volume_m3    Decimal   @default(0) @db.Decimal(14, 6)
  total_amount       Decimal   @default(0) @db.Decimal(15, 2)
  currency           String    @default("UZS") @db.VarChar(8)
  line_count         Int       @default(0)
  created_at         DateTime  @default(now())
  tenant             Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  warehouse          Warehouse @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)
  created_by         User?     @relation("WarehouseCorrectionCreator", fields: [created_by_user_id], references: [id])
  lines              WarehouseCorrectionLine[]

  @@index([tenant_id, created_at(sort: Desc)])
  @@index([tenant_id, warehouse_id])
  @@index([tenant_id, kind])
  @@map("warehouse_corrections")
}


model WarehouseCorrectionLine {
  id          Int                 @id @default(autoincrement())
  document_id Int
  product_id  Int
  qty_before  Decimal             @db.Decimal(15, 3)
  qty_delta   Decimal             @db.Decimal(15, 3)
  price_unit  Decimal?            @db.Decimal(15, 2)
  line_amount Decimal?            @db.Decimal(15, 2)
  volume_m3   Decimal?            @db.Decimal(14, 6)
  document    WarehouseCorrection @relation(fields: [document_id], references: [id], onDelete: Cascade)
  product     Product             @relation(fields: [product_id], references: [id], onDelete: Restrict)

  @@index([document_id])
  @@index([product_id])
  @@map("warehouse_correction_lines")
}

/// Ta’minotchilar (поступление)

model Supplier {
  id             Int            @id @default(autoincrement())
  tenant_id      Int
  name           String         @db.VarChar(255)
  code           String?        @db.VarChar(64)
  phone          String?        @db.VarChar(64)
  address        String?        @db.VarChar(512)
  /// UI / hisob-kitob tartibi (kichik = yuqorida)
  sort_order     Int            @default(0)
  /// Boshlang‘ich qarz (+) / kredit (−) ta’minotchiga nisbatan
  opening_balance      Decimal @default(0) @db.Decimal(15, 2)
  opening_balance_note String? @db.VarChar(2000)
  comment        String?
  is_active      Boolean        @default(true)
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  goods_receipts GoodsReceipt[]
  supplier_payments SupplierPayment[]
  tenant         Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@index([tenant_id, is_active])
  @@index([tenant_id, sort_order])
  @@map("suppliers")
}

/// Ta’minotchiga to‘langan pullar (qarzni kamaytirish)
