model SupplierPayment {
  id                   Int       @id @default(autoincrement())
  tenant_id            Int
  supplier_id          Int
  amount               Decimal   @db.Decimal(15, 2)
  paid_at              DateTime  @default(now())
  payment_method       String?   @db.VarChar(128)
  comment              String?   @db.VarChar(2000)
  created_by_user_id   Int?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  /// Chiqim qaysi kassadan — qoldiq tekshiruvi
  cash_desk_id         Int?
  /// Storno (hard delete o‘rniga)
  reversed_at          DateTime?
  reversed_by_user_id  Int?
  /// Takroriy yuborishni oldini olish (client-generated)
  idempotency_key      String?   @db.VarChar(64)
  supplier             Supplier  @relation(fields: [supplier_id], references: [id], onDelete: Restrict)
  tenant               Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  created_by           User?     @relation("SupplierPaymentCreator", fields: [created_by_user_id], references: [id], onDelete: SetNull)
  cash_desk            CashDesk? @relation(fields: [cash_desk_id], references: [id], onDelete: SetNull)
  reversed_by          User?     @relation("SupplierPaymentReverser", fields: [reversed_by_user_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, supplier_id])
  @@index([tenant_id, paid_at(sort: Desc)])
  @@index([tenant_id, cash_desk_id])
  @@index([tenant_id, payment_method])
  @@index([tenant_id, created_at(sort: Desc)])
  @@map("supplier_payments")
}

/// Omborga hujjatli kirim (Поступление)

model GoodsReceipt {
  id                 Int                @id @default(autoincrement())
  tenant_id          Int
  number             String             @db.VarChar(40)
  warehouse_id       Int
  supplier_id        Int?
  /// draft | posted | cancelled
  status             String             @default("posted") @db.VarChar(16)
  receipt_at         DateTime?
  comment            String?
  price_type         String             @db.VarChar(128)
  external_ref       String?            @db.VarChar(128)
  total_qty          Decimal            @default(0) @db.Decimal(15, 3)
  total_sum          Decimal            @default(0) @db.Decimal(15, 2)
  total_volume_m3    Decimal            @default(0) @db.Decimal(18, 6)
  total_weight_kg    Decimal            @default(0) @db.Decimal(18, 4)
  created_by_user_id Int?
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  deleted_at         DateTime?
  deleted_by_user_id Int?
  delete_reason_ref  String?            @db.VarChar(128)
  lines              GoodsReceiptLine[]
  created_by         User?              @relation("GoodsReceiptCreator", fields: [created_by_user_id], references: [id])
  deleted_by         User?              @relation("GoodsReceiptVoidedBy", fields: [deleted_by_user_id], references: [id], onDelete: SetNull)
  supplier           Supplier?          @relation(fields: [supplier_id], references: [id])
  tenant             Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  warehouse          Warehouse          @relation(fields: [warehouse_id], references: [id])

  @@unique([tenant_id, number])
  @@index([tenant_id, warehouse_id])
  @@index([tenant_id, supplier_id])
  @@index([tenant_id, status])
  @@index([tenant_id, created_at(sort: Desc)])
  @@index([tenant_id, deleted_at])
  @@map("goods_receipts")
}


model GoodsReceiptLine {
  id         Int          @id @default(autoincrement())
  receipt_id Int
  product_id Int
  qty        Decimal      @db.Decimal(15, 3)
  unit_price Decimal      @db.Decimal(15, 2)
  line_total Decimal      @db.Decimal(15, 2)
  defect_qty Decimal?     @db.Decimal(15, 3)
  volume_m3  Decimal?     @db.Decimal(14, 6)
  weight_kg  Decimal?     @db.Decimal(12, 4)
  sort_order Int          @default(0)
  product    Product      @relation(fields: [product_id], references: [id])
  receipt    GoodsReceipt @relation(fields: [receipt_id], references: [id], onDelete: Cascade)

  @@index([receipt_id])
  @@index([product_id])
  @@map("goods_receipt_lines")
}


model Order {
  id                          Int              @id @default(autoincrement())
  tenant_id                   Int
  number                      String
  client_id                   Int
  agent_id                    Int?
  warehouse_id                Int?
  /// Hujjat tipi: order | return | exchange | partial_return | return_by_order
  order_type                  String           @default("order") @db.VarChar(20)
  status                      String           @default("new")
  total_sum                   Decimal          @default(0) @db.Decimal(15, 2)
  bonus_sum                   Decimal          @default(0) @db.Decimal(15, 2)
  /// Foizli chegirma summasi (bonus qo‘llashda `total_sum` dan oldingi yig‘indi − chegirmadan keyin)
  discount_sum                Decimal          @default(0) @db.Decimal(15, 2)
  created_at                  DateTime         @default(now())
  updated_at                  DateTime         @updatedAt
  /// Faqat `once_per_client` bo‘lgan va shu zakazda avtomatik qo‘llangan qoidalar (takrorlanmasligi uchun)
  applied_auto_bonus_rule_ids Int[]            @default([])
  /// Qty bonus: `bonus_rule_id` (string kalit) → tanlangan `bonus_product_id` (JSON obyekt)
  bonus_gift_selections       Json             @default("{}")
  expeditor_user_id           Int?
  /// Operator izohi (ichki)
  comment                     String?
  /// Sozlamalar → «Причины заявок» dan tanlangan kod/nom (test / filtr)
  request_type_ref            String?          @db.VarChar(128)
  /// Konsignatsiya (qarzga berilgan) savdo — agent limiti hisobiga kiradi
  is_consignment              Boolean          @default(false)
  /// Konsignatsiya to‘lash muddati (ixtiyoriy)
  consignment_due_date      DateTime?
  /// Obmen: manba zakazlar va minus/plus qatorlar (audit)
  exchange_meta             Json?
  /// Savdo zakazida majburiy: reja / tanlangan to‘lov usuli (spravochnik, masalan naqd)
  payment_method_ref        String?          @db.VarChar(64)
  /// Skladchi yig‘gan zakazni qaysi «доставщик bloki»ga qo‘ygani (bitta blok = bitta ekspektor).
  warehouse_block_id        Int?
  payments                    Payment[]
  change_logs                 OrderChangeLog[]
  items                       OrderItem[]
  status_logs                 OrderStatusLog[]
  agent                       User?            @relation("OrderAgents", fields: [agent_id], references: [id])
  client                      Client           @relation(fields: [client_id], references: [id])
  expeditor_user              User?            @relation("OrderExpeditor", fields: [expeditor_user_id], references: [id])
  tenant                      Tenant           @relation(fields: [tenant_id], references: [id])
  warehouse                   Warehouse?       @relation(fields: [warehouse_id], references: [id])
  warehouse_block             WarehouseBlock?  @relation(fields: [warehouse_block_id], references: [id], onDelete: SetNull)
  sales_returns               SalesReturn[]
  client_photo_reports        ClientPhotoReport[]

  @@unique([tenant_id, number])
  @@index([tenant_id, status])
  @@index([tenant_id, expeditor_user_id])
  /// Dashboard / monitoring: sana + `order_type` bo‘yicha tez filtr
  @@index([tenant_id, order_type, created_at(sort: Desc)])
  @@index([tenant_id, status, created_at(sort: Desc)])
  @@index([tenant_id, client_id, order_type, status])
  @@index([tenant_id, client_id, created_at(sort: Desc)])
  /// Dashboard / monitoring: agent + vaqt oralig‘i bilan filtr
  @@index([tenant_id, order_type, agent_id, created_at(sort: Desc)])
  /// Agent katalogi: order_items orqali DISTINCT product_id so‘rovlari
  @@index([tenant_id, agent_id, order_type])
  @@index([tenant_id, agent_id, status])
  @@index([tenant_id, client_id, status])
  @@index([warehouse_block_id])
  @@map("orders")
}


model OrderStatusLog {
  id          Int      @id @default(autoincrement())
  order_id    Int
  from_status String
  to_status   String
  user_id     Int?
  created_at  DateTime @default(now())
  order       Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [user_id], references: [id])

  @@index([order_id])
  @@index([order_id, to_status, created_at(sort: Desc)])
  @@map("order_status_logs")
}

/// Zakaz bo‘yicha tahrir jurnali (qatorlar, ombor/agent) — kim va qachon.

model OrderChangeLog {
  id         Int      @id @default(autoincrement())
  order_id   Int
  user_id    Int?
  action     String
  payload    Json     @default("{}")
  created_at DateTime @default(now())
  order      Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [user_id], references: [id])

  @@index([order_id])
  @@map("order_change_logs")
}

/// Mijozdan kelgan to‘lov (balansga qo‘shiladi) yoki rasxod / qarz (balansdan yechiladi).

model Payment {
  id                 Int       @id @default(autoincrement())
  tenant_id          Int
  client_id          Int
  order_id           Int?
  amount             Decimal   @db.Decimal(15, 2)
  payment_type       String    @db.VarChar(64)
  note               String?
  created_by_user_id Int?
  created_at         DateTime  @default(now())
  /// Kassa punkti (filtr «Касса»)
  cash_desk_id       Int?
  /// pending_confirmation | confirmed | rejected | deleted (архив)
  workflow_status    String    @default("confirmed") @db.VarChar(32)
  paid_at            DateTime?
  received_at        DateTime?
  confirmed_at       DateTime?
  /// payment — kirim; client_expense — «расход клиента» (qarz / balansdan chiqim)
  entry_kind         String    @default("payment") @db.VarChar(24)
  /// Zakazsiz rasxod qatorida ekskpeditor (order.expeditor o‘rniga)
  expeditor_user_id  Int?
  /// Vedoma: `COALESCE(ledger_agent_id, zakaz.agent_id, mijoz.agent_id)`
  ledger_agent_id    Int?
  /// Yumshoq bekor (arxiv): NULL = faol
  deleted_at         DateTime?
  deleted_by_user_id Int?
  delete_reason_ref  String?   @db.VarChar(128)
  client             Client    @relation(fields: [client_id], references: [id], onDelete: Cascade)
  created_by         User?     @relation("PaymentCreator", fields: [created_by_user_id], references: [id])
  deleted_by         User?     @relation("PaymentVoidedBy", fields: [deleted_by_user_id], references: [id], onDelete: SetNull)
  expeditor_user     User?     @relation("PaymentExpeditor", fields: [expeditor_user_id], references: [id], onDelete: SetNull)
  ledger_agent       User?     @relation("PaymentLedgerAgent", fields: [ledger_agent_id], references: [id], onDelete: SetNull)
  order              Order?    @relation(fields: [order_id], references: [id])
  tenant             Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  cash_desk          CashDesk? @relation(fields: [cash_desk_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, client_id])
  @@index([tenant_id, client_id, entry_kind])
  @@index([tenant_id, created_at(sort: Desc)])
  @@index([tenant_id, order_id])
  @@index([tenant_id, workflow_status])
  @@index([tenant_id, deleted_at])
  @@index([cash_desk_id])
  @@index([tenant_id, entry_kind])
  @@index([tenant_id, client_id, deleted_at, entry_kind])
  @@index([tenant_id, order_id, deleted_at, entry_kind])
  @@index([tenant_id, entry_kind, deleted_at, paid_at(sort: Desc)])
  @@index([tenant_id, paid_at(sort: Desc)])
  @@index([expeditor_user_id])
  @@index([ledger_agent_id])
  @@map("client_payments")
}

/// Mahsulot qaytarish — ombor qoldig’ini oshiradi, ixtiyoriy pul qaytarish balansga.

model SalesReturn {
  id                 Int               @id @default(autoincrement())
  tenant_id          Int
  number             String            @db.VarChar(48)
  client_id          Int?
  order_id           Int?
  warehouse_id       Int
  /// posted | cancelled
  status             String            @default("posted") @db.VarChar(16)
  refund_amount      Decimal?          @db.Decimal(15, 2)
  note               String?
  /// «Причины отказа» spravochnikidan kod/nom
  refusal_reason_ref String?           @db.VarChar(128)
  created_by_user_id Int?
  created_at         DateTime          @default(now())
  /// Davr asosidagi vazvrat uchun
  date_from          DateTime?
  date_to            DateTime?
  /// Vazvrat turi: order_full (holat o’zgartirish) yoki partial (polki — ro’yxatdan tanlab qaytarish)
  return_type        String            @default("partial") @db.VarChar(20)
  lines              SalesReturnLine[]
  client             Client?           @relation(fields: [client_id], references: [id])
  created_by         User?             @relation("SalesReturnCreator", fields: [created_by_user_id], references: [id])
  order              Order?            @relation(fields: [order_id], references: [id])
  tenant             Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  warehouse          Warehouse         @relation(fields: [warehouse_id], references: [id])

  @@unique([tenant_id, number])
  @@index([tenant_id, created_at(sort: Desc)])
  @@index([tenant_id, order_id, status])
  @@map("sales_returns")
}


model SalesReturnLine {
  id         Int         @id @default(autoincrement())
  return_id  Int
  product_id Int
  qty        Decimal     @db.Decimal(15, 3)
  /// Shu qaytarishdagi bepul/bonus qismi
  bonus_qty  Decimal?    @db.Decimal(15, 3)
  /// Shu qaytarishdagi pullik qismi (bonus qayta hisoblashdan keyin)
  paid_qty   Decimal?    @db.Decimal(15, 3)
  product    Product     @relation(fields: [product_id], references: [id])
  return     SalesReturn @relation(fields: [return_id], references: [id], onDelete: Cascade)

  @@index([return_id])
  @@index([product_id])
  @@map("sales_return_lines")
}


model OrderItem {
  id         Int     @id @default(autoincrement())
  order_id   Int
  product_id Int
  /// `exchange` hujjatida: `minus` (klientdan qaytgan) yoki `plus` (yangi chiqim)
  exchange_line_kind String? @db.VarChar(16)
  qty        Decimal @db.Decimal(15, 3)
  price      Decimal @db.Decimal(15, 2)
  total      Decimal @db.Decimal(15, 2)
  is_bonus   Boolean @default(false)
  order      Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [product_id], references: [id])

  @@index([order_id])
  @@index([order_id, product_id])
  @@index([product_id, order_id])
  @@map("order_items")
}

/// Направление торговли (spravochnik; `User.trade_direction` saqlangan qiymat bilan mos: code yoki name)

model TradeDirection {
  id                    Int      @id @default(autoincrement())
  tenant_id             Int
  name                  String
  sort_order            Int      @default(0)
  code                  String?  @db.VarChar(20)
  comment               String?
  is_active             Boolean  @default(true)
  use_in_order_proposal Boolean  @default(false)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  tenant                Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  staff_users           User[]     @relation("UserTradeDirection")
  work_slots            WorkSlot[]

  @@unique([tenant_id, code])
  @@index([tenant_id, is_active])
  @@map("trade_directions")
}

/// Канал продаж (spravochnik; `Client.sales_channel` bilan mos: code yoki name)

model SalesChannelRef {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  name       String
  code       String?  @db.VarChar(20)
  comment    String?
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, code])
  @@index([tenant_id, is_active])
  @@map("sales_channel_refs")
}


model KpiGroup {
  id         Int               @id @default(autoincrement())
  tenant_id  Int
  name       String
  code       String?           @db.VarChar(20)
  sort_order Int               @default(0)
  comment    String?
  is_active  Boolean           @default(true)
  created_at DateTime          @default(now())
  updated_at DateTime          @updatedAt
  agents     KpiGroupAgent[]
  products   KpiGroupProduct[]
  tenant     Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, is_active])
  @@map("kpi_groups")
}

