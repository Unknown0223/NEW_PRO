model KpiGroupProduct {
  kpi_group_id Int
  product_id   Int
  kpi_group    KpiGroup @relation(fields: [kpi_group_id], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@id([kpi_group_id, product_id])
  @@index([product_id])
  @@map("kpi_group_products")
}


model KpiGroupAgent {
  kpi_group_id Int
  user_id      Int
  kpi_group    KpiGroup @relation(fields: [kpi_group_id], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([kpi_group_id, user_id])
  @@index([user_id])
  @@map("kpi_group_agents")
}

/// Mahsulot uchun kategoriya/tur/kanal bo'yicha narx matritsasi — `ProductPrice` ustidan qo'shimcha chegirma/koeffitsiyent

model PriceMatrix {
  id              Int       @id @default(autoincrement())
  tenant_id       Int
  product_id      Int
  client_category String    @db.VarChar(128)
  client_type     String?   @db.VarChar(128)
  sales_channel   String?   @db.VarChar(128)
  price           Decimal   @db.Decimal(15, 2)
  min_price       Decimal?  @db.Decimal(15, 2)
  max_price       Decimal?  @db.Decimal(15, 2)
  currency        String    @default("UZS") @db.VarChar(8)
  valid_from      DateTime?
  valid_to        DateTime?
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  product         Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, product_id, client_category, client_type, sales_channel, currency])
  @@index([tenant_id, client_category])
  @@index([tenant_id, product_id])
  @@map("price_matrix")
}

/// KPI natijalari (agent performance tracking)

model KpiResult {
  id            Int      @id @default(autoincrement())
  tenant_id     Int
  user_id       Int
  kpi_group_id  Int?
  period_month  String   @db.VarChar(7) // "2026-04"
  metric        String   @db.VarChar(64) // "sales_volume", "order_count", "payment_rate", ...
  value         Decimal  @db.Decimal(15, 2)
  target        Decimal? @db.Decimal(15, 2)
  score         Decimal? @db.Decimal(5, 2) // 0-100
  comment       String?
  calculated_at DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, user_id, period_month])
  @@map("kpi_results")
}


model BonusRule {
  id                   Int                  @id @default(autoincrement())
  tenant_id            Int
  name                 String
  type                 String
  buy_qty              Int?
  free_qty             Int?
  min_sum              Decimal?             @db.Decimal(15, 2)
  /// order = faqat joriy zakaz; calendar_month = mijoz uchun to‘liq kalendar oyidagi zakazlar yig‘indisi + joriy zakaz (chegirmadan oldingi pullik summa).
  sum_threshold_scope  String               @default("order") @db.VarChar(32)
  discount_pct         Decimal?             @db.Decimal(5, 2)
  priority             Int                  @default(0)
  is_active            Boolean              @default(true)
  valid_from           DateTime?
  valid_to             DateTime?
  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt
  /// Doctor-style: mijoz toifasi (Client.category bilan mos kelishi mumkin)
  client_category      String?
  payment_type         String?
  client_type          String?
  sales_channel        String?
  price_type           String?
  /// Bo‘sh = barcha mahsulotlar (engine talqini)
  product_ids          Int[]                @default([])
  bonus_product_ids    Int[]                @default([])
  product_category_ids Int[]                @default([])
  target_all_clients   Boolean              @default(true)
  selected_client_ids  Int[]                @default([])
  is_manual            Boolean              @default(false)
  /// true: har to‘liq blok uchun bonus (masalan 13 ta → 6+6 → 2 bonus); false: engine boshqa siyosat
  in_blocks            Boolean              @default(true)
  once_per_client      Boolean              @default(false)
  one_plus_one_gift    Boolean              @default(false)
  /// Shu qoida qo‘llanishidan oldin zakazda bajarilgan bo‘lishi kerak bo‘lgan boshqa avto-qoidalar (ID lar tartibsiz).
  prerequisite_rule_ids Int[]              @default([])
  /// Bo‘sh = filial cheklovi yo‘q. `User.branch` bilan mos (trim, case-insensitive).
  scope_branch_codes         String[] @default([])
  /// Bo‘sh = aniq agent tanlovi yo‘q. Zakaz `agent_id` shu ro‘yxatda bo‘lishi kerak (filial bilan birga — OR).
  scope_agent_user_ids       Int[]    @default([])
  /// Bo‘sh = yo‘nalish cheklovi yo‘q. Agent `trade_direction_id` shu ID lardan biri bo‘lishi kerak.
  scope_trade_direction_ids  Int[]    @default([])
  conditions           BonusRuleCondition[]
  tenant               Tenant               @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("bonus_rules")
}


model BonusRuleCondition {
  id            Int       @id @default(autoincrement())
  bonus_rule_id Int
  min_qty       Decimal?  @db.Decimal(15, 3)
  max_qty       Decimal?  @db.Decimal(15, 3)
  step_qty      Decimal   @db.Decimal(15, 3)
  bonus_qty     Decimal   @db.Decimal(15, 3)
  max_bonus_qty Decimal?  @db.Decimal(15, 3)
  sort_order    Int       @default(0)
  bonus_rule    BonusRule @relation(fields: [bonus_rule_id], references: [id], onDelete: Cascade)

  @@index([bonus_rule_id])
  @@map("bonus_rule_conditions")
}

/// Kassa (kassa punkti) — foydalanuvchilar rollari va joylashuv

model CashDesk {
  id         Int                @id @default(autoincrement())
  tenant_id  Int
  name       String
  timezone   String             @default("Asia/Tashkent") @db.VarChar(64)
  sort_order Int?
  code       String?            @db.VarChar(20)
  comment    String?
  latitude   Decimal?           @db.Decimal(10, 7)
  longitude  Decimal?           @db.Decimal(10, 7)
  is_active  Boolean            @default(true)
  /// Yopilgan / yakunlangan sessiya holati (UI «статус закрытия»)
  is_closed  Boolean            @default(false)
  created_at DateTime           @default(now())
  updated_at DateTime           @updatedAt
  shifts                      CashDeskShift[]
  links                       CashDeskUserLink[]
  payments                    Payment[]
  opening_balance_entries     ClientOpeningBalanceEntry[]
  supplier_payments           SupplierPayment[]
  tenant                      Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, is_active])
  @@map("cash_desks")
}

/// Bir kassaga biriktirilgan foydalanuvchi (bir foydalanuvchi bir kassada faqat bitta «rol slot»ida)

model CashDeskUserLink {
  id           Int      @id @default(autoincrement())
  cash_desk_id Int
  user_id      Int
  /// cashier | manager | operator | supervisor | expeditor
  link_role    String   @db.VarChar(32)
  created_at   DateTime @default(now())
  cash_desk    CashDesk @relation(fields: [cash_desk_id], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([cash_desk_id, user_id])
  @@index([cash_desk_id, link_role])
  @@index([user_id])
  @@map("cash_desk_user_links")
}

/// Kassa smenasi: ochish/yopish, kassa qoldiqlari.

model CashDeskShift {
  id                Int       @id @default(autoincrement())
  tenant_id         Int
  cash_desk_id      Int
  opened_at         DateTime  @default(now())
  closed_at         DateTime?
  opened_by_user_id Int?
  closed_by_user_id Int?
  opening_float     Decimal?  @db.Decimal(15, 2)
  closing_float     Decimal?  @db.Decimal(15, 2)
  notes             String?
  cash_desk         CashDesk  @relation(fields: [cash_desk_id], references: [id], onDelete: Cascade)
  closed_by         User?     @relation("CashDeskShiftClosedBy", fields: [closed_by_user_id], references: [id])
  opened_by         User?     @relation("CashDeskShiftOpenedBy", fields: [opened_by_user_id], references: [id])
  tenant            Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, cash_desk_id])
  @@index([cash_desk_id, closed_at])
  @@map("cash_desk_shifts")
}

/// Kunlik valyuta kursi: 1 base_currency = rate quote_currency (spravochnikdagi kodlar bilan).

model CurrencyExchangeRate {
  id                 Int      @id @default(autoincrement())
  tenant_id          Int
  rate_date          DateTime @db.Date
  base_currency      String   @db.VarChar(8)
  quote_currency     String   @db.VarChar(8)
  rate               Decimal  @db.Decimal(20, 8)
  source             String?  @db.VarChar(64)
  note               String?  @db.VarChar(500)
  created_by_user_id Int?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, rate_date, base_currency, quote_currency])
  @@index([tenant_id, rate_date])
  @@map("currency_exchange_rates")
}

/// Inventarizatsiya hujjati (draft → posted).

model StockTake {
  id                 Int             @id @default(autoincrement())
  tenant_id          Int
  warehouse_id       Int
  status             String          @default("draft") @db.VarChar(16)
  title              String?         @db.VarChar(500)
  notes              String?
  created_by_user_id Int?
  posted_at          DateTime?
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt
  lines              StockTakeLine[]
  created_by         User?           @relation("StockTakeCreator", fields: [created_by_user_id], references: [id])
  tenant             Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  warehouse          Warehouse       @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, warehouse_id])
  @@index([tenant_id, status])
  @@map("stock_takes")
}


model StockTakeLine {
  id            Int       @id @default(autoincrement())
  stock_take_id Int
  product_id    Int
  system_qty    Decimal   @db.Decimal(15, 3)
  counted_qty   Decimal?  @db.Decimal(15, 3)
  product       Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  stock_take    StockTake @relation(fields: [stock_take_id], references: [id], onDelete: Cascade)

  @@unique([stock_take_id, product_id])
  @@index([stock_take_id])
  @@map("stock_take_lines")
}

/// Agent tashrif / check-in (maydon).

model AgentVisit {
  id             Int       @id @default(autoincrement())
  tenant_id      Int
  agent_id       Int
  client_id      Int?
  checked_in_at  DateTime  @default(now())
  checked_out_at DateTime?
  latitude       Decimal?  @db.Decimal(11, 8)
  longitude      Decimal?  @db.Decimal(11, 8)
  notes          String?
  agent          User      @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  client         Client?   @relation(fields: [client_id], references: [id])
  tenant         Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, agent_id])
  @@index([tenant_id, checked_in_at(sort: Desc)])
  @@index([tenant_id, agent_id, checked_in_at(sort: Desc)])
  @@index([tenant_id, client_id, checked_in_at(sort: Desc)])
  @@map("agent_visits")
}

/// Agent GPS ping (mobil ilova / trek).

model AgentLocationPing {
  id              Int      @id @default(autoincrement())
  tenant_id       Int
  agent_id        Int
  latitude        Decimal  @db.Decimal(11, 8)
  longitude       Decimal  @db.Decimal(11, 8)
  accuracy_meters Float?
  recorded_at     DateTime @default(now())
  agent           User     @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, agent_id, recorded_at])
  @@map("agent_location_pings")
}


model TenantTask {
  id                 Int       @id @default(autoincrement())
  tenant_id          Int
  title              String    @db.VarChar(500)
  /// «Типы задач» spravochnikidan kod/nom
  task_type_ref      String?   @db.VarChar(128)
  description        String?
  status             String    @default("open") @db.VarChar(32)
  priority           String    @default("normal") @db.VarChar(16)
  due_at             DateTime?
  assignee_user_id   Int?
  created_by_user_id Int?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  assignee           User?     @relation("TenantTaskAssignee", fields: [assignee_user_id], references: [id])
  created_by         User?     @relation("TenantTaskCreator", fields: [created_by_user_id], references: [id])
  tenant             Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, status])
  @@index([tenant_id, assignee_user_id])
  @@map("tenant_tasks")
}

/// Kunlik marshrut (agent + sana + mijozlar tartibi).

model AgentRouteDay {
  id         Int      @id @default(autoincrement())
  tenant_id  Int
  agent_id   Int
  route_date DateTime
  stops      Json     @default("[]")
  notes      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  agent      User     @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, agent_id, route_date])
  @@index([tenant_id, route_date])
  @@map("agent_route_days")
}

/// Ilova ichidagi bildirishnomalar (push o’rniga polling / keyinroq FCM).

model InAppNotification {
  id         Int       @id @default(autoincrement())
  tenant_id  Int
  user_id    Int
  title      String    @db.VarChar(500)
  body       String?
  link_href  String?   @db.VarChar(512)
  read_at    DateTime?
  created_at DateTime  @default(now())
  tenant     Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, user_id, read_at])
  @@map("in_app_notifications")
}

/// Hudud / Territory — agentlarga biriktiriladigan savdo hududlari
